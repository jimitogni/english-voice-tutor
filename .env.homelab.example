# Public traffic uses http://PUBLIC_APPS_HOST:8888/WEB_BASE_PATH.
# The router forwards public :8888 to Traefik on this server's host port 80.
PUBLIC_APPS_HOST=jimitogni.duckdns.org
TRAEFIK_NETWORK=traefik_proxy
TRAEFIK_HTTP_ENTRYPOINT=web
TRAEFIK_HTTPS_ENTRYPOINT=websecure
TRAEFIK_HTTPS_HOST_PORT=8443
TRAEFIK_CERT_RESOLVER=duckdns
WEB_BASE_PATH=/english
QDRANT_PORT=6333

# Leave this empty when serving at /. If WEB_BASE_PATH is a path such as
# /english, set this to the same value so browser API calls use /english/api.
PUBLIC_API_BASE_URL=/english

# Local assistant identity.
SERVICE_NAME=english-voice-tutor
OBSERVABILITY_ENV=homelab
LOG_LEVEL=INFO
LOG_JSON=true
ASSISTANT_NAME=Jarvis
USER_DISPLAY_NAME="Jimi Jeday Marster"

# Ollama runs as a Docker Compose service named "ollama".
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
EXTRA_OLLAMA_MODELS="qwen3:4b gemma3:4b"

# Conversation and practice settings.
CONVERSATION_HISTORY_TURNS=40
FOCUS_WORDS_LIMIT=10
SAVE_CONVERSATIONS=true

# Local RAG over files in ./data/knowledge, backed by Qdrant and Ollama embeddings.
RAG_ENABLED=true
RAG_VECTOR_DB=qdrant
RAG_EMBEDDING_MODEL=embeddinggemma
RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.25
RAG_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP=120
RAG_CONTEXT_CHAR_LIMIT=3500
RAG_REQUEST_TIMEOUT_SECONDS=30
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=english_voice_tutor_knowledge
KNOWLEDGE_DIR=/app/data/knowledge

# Speech-to-text.
STT_MODEL_SIZE=base
STT_LANGUAGE=en
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
PRONUNCIATION_FEEDBACK=true

# Browser VAD defaults exposed by the API.
RECORD_SECONDS=8
RECORD_MODE=fixed
SAMPLE_RATE=16000
VAD_ENERGY_THRESHOLD=0.015
VAD_SILENCE_SECONDS=2.2
VAD_MIN_SPEECH_SECONDS=0.4
VAD_MAX_SECONDS=300
VAD_CHUNK_MS=30

# LLM/TTS behavior.
LLM_STREAM=true
TTS_ENGINE=piper
STREAM_TTS=false
PIPER_CUDA=false
PIPER_EXECUTABLE=piper

# Container paths. The ./models directory is mounted at /app/models.
PIPER_MODEL_PATH=/app/models/piper/en_US-lessac-medium.onnx
PIPER_CONFIG_PATH=/app/models/piper/en_US-lessac-medium.onnx.json

# Observability.
# Set ENABLE_LANGFUSE_STACK=1 to start the bundled Langfuse stack from
# docker-compose.langfuse.yml. LANGFUSE_HOST must stay reachable from the API
# container, while LANGFUSE_PUBLIC_URL is where you open the Langfuse UI.
ENABLE_LANGFUSE_STACK=0
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_HOST=langfuse-jimitogni.duckdns.org
LANGFUSE_PUBLIC_URL=http://langfuse-jimitogni.duckdns.org:8888
LANGFUSE_PUBLIC_KEY=lf_pk_replace_me
LANGFUSE_SECRET_KEY=lf_sk_replace_me
LANGFUSE_UI_PORT=3000
LANGFUSE_TELEMETRY_ENABLED=false
LANGFUSE_NEXTAUTH_SECRET=replace_me
LANGFUSE_SALT=replace_me
LANGFUSE_ENCRYPTION_KEY=replace_with_64_hex_chars
LANGFUSE_POSTGRES_USER=postgres
LANGFUSE_POSTGRES_PASSWORD=replace_me
LANGFUSE_POSTGRES_DB=postgres
LANGFUSE_POSTGRES_VERSION=17
LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=replace_me
LANGFUSE_REDIS_AUTH=replace_me
LANGFUSE_MINIO_ROOT_USER=minio
LANGFUSE_MINIO_ROOT_PASSWORD=replace_me
LANGFUSE_MINIO_API_PORT=9090
LANGFUSE_MINIO_CONSOLE_PORT=9091
LANGFUSE_S3_BUCKET=langfuse
LANGFUSE_S3_REGION=auto
LANGFUSE_INIT_ORG_ID=english-voice-tutor
LANGFUSE_INIT_ORG_NAME=English Voice Tutor
LANGFUSE_INIT_PROJECT_ID=english-voice-tutor
LANGFUSE_INIT_PROJECT_NAME=English Voice Tutor
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=lf_pk_replace_me
LANGFUSE_INIT_PROJECT_SECRET_KEY=lf_sk_replace_me
LANGFUSE_INIT_USER_EMAIL=replace_me@example.com
LANGFUSE_INIT_USER_NAME=English Voice Tutor Admin
LANGFUSE_INIT_USER_PASSWORD=replace_me

EVIDENTLY_ENABLED=true
EVIDENTLY_REPORTS_DIR=/app/data/reports/evidently

METRICS_ENABLED=true
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true

PRIVACY_REDACT_PROMPTS=false
PRIVACY_REDACT_RESPONSES=false
PRIVACY_HASH_USER_ID=true
